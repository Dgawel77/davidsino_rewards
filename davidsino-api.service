[Unit]
Description=Davidsino Rewards API Server
After=network.target postgresql.service

[Service]
Type=notify
User=dgawel
WorkingDirectory=/home/dgawel/.openclaw/workspace/davidsino-rewards
ExecStart=/home/dgawel/.openclaw/workspace/davidsino-rewards/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
